# Stripe secret key (test key recommended)
STRIPE_SECRET_KEY=sk_test_123

# Webhook signing secret from `stripe listen` or Dashboard
STRIPE_WEBHOOK_SECRET=whsec_123

# Allowed frontend origin(s), comma-separated (protocol + host + port)
# Example local + Tailscale frontend URL:
# CLIENT_ORIGIN=http://localhost:5173,http://100.64.0.10:5173
CLIENT_ORIGIN=http://localhost:5173

# Comma-separated list of allowed Stripe Price IDs (optional hardening)
# Example: price_abc,price_def
ALLOWED_PRICE_IDS=

# Optional: service account JSON path for Firebase Admin SDK
# Required to enable server-protected admin order updates
# Example: ../service-account.json
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=

# Optional inline JSON alternative to path (leave empty unless needed)
FIREBASE_SERVICE_ACCOUNT_JSON=
